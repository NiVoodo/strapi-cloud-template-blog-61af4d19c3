{
  "kind": "singleType",
  "collectionName": "globals",
  "info": {
    "singularName": "global",
    "pluralName": "globals",
    "displayName": "Global Settings",
    "description": "Site-wide defaults and SEO fallbacks"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "siteName": { "type": "string", "required": true },
    "defaultShareImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "defaultMetaTitleSuffix": { "type": "string", "default": " | Your Brand" },
    "defaultCanonicalBase": { "type": "string", "required": false },
    "seoDefaults": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "twitterHandle": { "type": "string" },
    "facebookAppId": { "type": "string" },
    "robotsDefaultNoindex": { "type": "boolean", "default": false },
    "robotsDefaultNofollow": { "type": "boolean", "default": false }
  }
}
