{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "SEO",
    "description": "Per-Page SEO settings with sensible defaults"
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "required": false,
      "maxLength": 60
    },
    "metaDescription": {
      "type": "text",
      "required": false,
      "maxLength": 160
    },
    "shareImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "canonicalURL": {
      "type": "string"
    },
    "noindex": {
      "type": "boolean",
      "default": false
    },
    "nofollow": {
      "type": "boolean",
      "default": false
    },
    "structuredData": {
      "type": "json",
      "required": false
    },
    "ogTitle": {
      "type": "string"
    },
    "ogDescription": {
      "type": "text"
    },
    "twitterTitle": {
      "type": "string"
    },
    "twitterDescription": {
      "type": "text"
    }
  }
}
