{
  "collectionName": "components_blocks_article_sliders",
  "info": {
    "displayName": "Article Slider",
    "description": "Zeigt Blog-Artikel als horizontalen Slider an"
  },
  "options": {},
  "attributes": {
    "eyebrow": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "limit": {
      "type": "integer",
      "default": 6,
      "min": 1,
      "max": 20
    },
    "category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::category.category"
    },
    "variant": {
      "type": "enumeration",
      "enum": ["", "Full Bleed Cardslider", "Full bleed Posterslider", "Slider"],
      "required": false
    },
    "slides": {
      "type": "component",
      "repeatable": true,
      "component": "blocks.article-slider-slide"
    }
  }
}
